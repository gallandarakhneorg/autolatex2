#! /bin/sh
set -e
case "$1" in
    pre-rtupdate)
        # called before the default interpreter changes
        ;;
    rtupdate)
        # recompile for the new default interpreter
        py3compile -p autolatex-asymptote /usr/lib/python3/dist-packages/autolatex2/translators/asymptote
        ;;
    post-rtupdate)
        # clean up .pyc files for the old interpreter
        py3clean -p autolatex-asymptote /usr/lib/python3/dist-packages/autolatex2/translators/asymptote
        ;;
esac
