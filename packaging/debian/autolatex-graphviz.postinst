#!/bin/sh
set -e

case "$1" in
    configure)
        # Byte-compile Python files for the current default interpreter
        py3compile -p autolatex-graphviz /usr/lib/python3/dist-packages/autolatex2/translators/dot
        py3compile -p autolatex-graphviz /usr/lib/python3/dist-packages/autolatex2/translators/gxl
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
