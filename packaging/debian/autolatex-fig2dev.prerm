#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Remove byte-compiled Python files
        py3clean -p autolatex-fig2dev /usr/lib/python3/dist-packages/autolatex2/translators/xfig
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
